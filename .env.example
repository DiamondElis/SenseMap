# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# OpenAI (for embeddings and /answer)
OPENAI_API_KEY=

# Embedding backend and models (shared/python/config.py)
EMBEDDING_BACKEND=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_BGE_MODEL=BAAI/bge-small-en-v1.5

# Optional: embedding cache path
# SENSEMAP_EMBEDDING_CACHE=data/processed/embedding_cache.db

# API & Apps
API_HOST=0.0.0.0
API_PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Airflow (use postgres when running full stack)
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@airflow-db:5432/airflow

# Optional
LOG_LEVEL=INFO
